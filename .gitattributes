# Normalize line endings: LF in the repo, native on checkout for scripts.
* text=auto eol=lf
*.bat text eol=crlf
gradlew text eol=lf

# Treat these as binary (no diff/merge, no EOL conversion).
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.docx binary
*.jar binary
*.keystore binary
*.so binary
